{
  "name": "yukikaze-music",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alicezuberg930/music_player.git"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.6.3",
    "typescript": "5.9.2",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8"
  },
  "bugs": {
    "url": "https://github.com/alicezuberg930/music_player/issues"
  },
  "catalog": {
    "typescript": "5.9.2",
    "tsdown": "^0.17.2",
    "@types/node": "^24.10.1",
    "eslint": "^9.36.0"
  },
  "catalogs": {
    "express": {
      "express": "^5.0.1",
      "@types/express": "^5.0.1",
      "express-rate-limit": "^7.0.0"
    },
    "tailwind": {
      "@tailwindcss/vite": "^4.1.15",
      "tailwindcss": "^4.1.15"
    },
    "react": {
      "react": "^19.1.1",
      "react-dom": "^19.1.1",
      "@types/react": "^19.1.9",
      "@types/react-dom": "^19.1.9"
    },
    "multer": {
      "multer": "^2.0.2",
      "@types/multer": "^2.0.0"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://tien-music-player.site",
  "packageManager": "bun@1.3.4",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@yukikaze/web",
    "build:packages": "turbo run build --filter=@yukikaze/upload --filter=@yukikaze/lib --filter=@yukikaze/ui --filter=@yukikaze/db --filter=@yukikaze/email --filter=@yukikaze/middleware --filter=@yukikaze/redis --filter=@yukikaze/validator",
    "build:services": "turbo run build --filter=@yukikaze/gateway --filter=@yukikaze/song-service --filter=@yukikaze/user-service --filter=@yukikaze/auth-service",
    "dev:web": "turbo run dev --filter=@yukikaze/web",
    "dev:packages": "turbo run dev --filter=@yukikaze/lib --filter=@yukikaze/ui --filter=@yukikaze/db --filter=@yukikaze/email --filter=@yukikaze/middleware --filter=@yukikaze/redis --filter=@yukikaze/validator",
    "dev:services": "turbo run dev --filter=@yukikaze/gateway --filter=@yukikaze/song-service --filter=@yukikaze/user-service --filter=@yukikaze/auth-service",
    "deps:bump": "bunx npm-check-updates --deep -u && bun install",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check .",
    "check-types": "turbo run check-types",
    "start:web": "turbo run start --filter=@yukikaze/web",
    "start:services": "turbo run start --filter=@yukikaze/gateway --filter=@yukikaze/song-service --filter=@yukikaze/user-service --filter=@yukikaze/auth-service",
    "docker:start:dev": "docker compose -f ./docker-compose.dev.yml up -d",
    "docker:start:prod": "docker compose -f ./docker-compose.prod.yml up -d",
    "docker:stop:dev": "docker compose -f ./docker-compose.dev.yml down",
    "docker:stop:prod": "docker compose -f ./docker-compose.prod.yml down"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ]
}